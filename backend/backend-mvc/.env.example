DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dermascan
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

APP_NAME=DermaScan API
APP_VERSION=1.0.0
DEBUG=true

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

# AI_MODEL_VERSION=melanoma-v1.0
# AI_MODEL_ENDPOINT=http://localhost:8001/predict

CORS_ORIGINS=*
